{
  "projectName": "auto-trade-system",
  "claudeCodeVersion": "1.0",
  "language": "python",
  "pythonVersion": "3.11",
  "packageManager": "poetry",
  "venv": {
    "create": true,
    "type": "venv",
    "activateOnOpen": true
  },
  "projectStructure": {
    "srcDir": "src",
    "testsDir": "tests",
    "docsDir": "docs",
    "designDocsDir": "design",
    "decisionLogsDir": "decisions",
    "skillsDir": "skills",
    "configsDir": "config",
    "scriptsDir": "scripts"
  },
  "entryPoints": [
    "src/main.py",
    "src/app/__init__.py"
  ],
  "filesToPrioritize": [
    "design/*.md",
    "decisions/*.md",
    "skills/*.yaml",
    "docs/**",
    "README.md"
  ],
  "developmentFocus": {
    "prioritize": [
      "docs",
      "src",
      "tests"
    ],
    "docsTool": "mkdocs",
    "docsConfigFile": "mkdocs.yml"
  },
  "linting": {
    "tools": [
      "ruff",
      "flake8"
    ],
    "configFiles": [
      "pyproject.toml",
      ".flake8"
    ],
    "runOnSave": true
  },
  "formatting": {
    "tool": "black",
    "lineLength": 88,
    "runOnSave": true
  },
  "typeChecking": {
    "tool": "mypy",
    "configFile": "mypy.ini",
    "strict": true
  },
  "testing": {
    "framework": "pytest",
    "coverageTool": "coverage",
    "minCoveragePercent": 80,
    "testDiscoveryPattern": "tests/**/test_*.py",
    "runOnCI": true
  },
  "ci": {
    "provider": "github-actions",
    "workflows": [
      {
        "name": "python-ci",
        "file": ".github/workflows/python-ci.yml"
      }
    ]
  },
  "packaging": {
    "build": "poetry build",
    "artifact": "wheel"
  },
  "dependencies": {
    "production": [
      "pandas",
      "numpy",
      "pyyaml",
      "requests"
    ],
    "development": [
      "pytest",
      "coverage",
      "pytest-cov",
      "black",
      "ruff",
      "mypy",
      "mkdocs",
      "bandit"
    ]
  },
  "security": {
    "scanTools": [
      "bandit"
    ],
    "secretScanning": true,
    "forbiddenActions": [
      "execute_market_orders_in_development",
      "use_real_api_keys_in_repo",
      "exfiltrate_secrets",
      "auto_deploy_without_manual_review"
    ],
    "forbiddenDependencies": [
      "fabric",
      "paramiko"
    ],
    "networkAccessPolicy": {
      "allowExternalRequestsDuringTests": false,
      "requireMockingForExternalApis": true
    }
  },
  "safetyConstraints": {
    "no_live_trading_by_default": true,
    "require_manual_approval_for_real_trading": true,
    "decisionLogRequiredForRiskyChanges": true,
    "designDocRequiredForArchitectureChanges": true
  },
  "developmentGuidelines": {
    "docsFirst": true,
    "designAndDecisionPriority": [
      "design",
      "decisions",
      "skills"
    ],
    "commitMessageConvention": "Conventional Commits",
    "codeReviewRequired": true,
    "testsRequiredForPR": true
  },
  "workflowHints": {
    "localSetupCommands": [
      "python -m venv .venv",
      "source .venv/bin/activate",
      "poetry install"
    ],
    "runTestsCommand": "pytest --cov=src",
    "lintCommand": "ruff check src tests && black --check .",
    "formatCommand": "black ."
  }
}