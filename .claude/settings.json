{
  "projectName": "auto-trading-system",
  "description": "Claude Code project settings for automated trading system development (Python-focused). Prioritizes docs, src, tests and safe development practices.",
  "environment": {
    "language": "python",
    "pythonVersion": "3.11",
    "packageManager": "poetry",
    "virtualEnv": "venv",
    "dependencyLock": true
  },
  "layout": {
    "src": "src",
    "tests": "tests",
    "docs": "docs",
    "designs": "designs",
    "decisionLogs": "docs/decision_logs",
    "skills": "skills",
    "artifacts": "dist",
    "localData": "data"
  },
  "priorities": [
    "designs",
    "docs/decision_logs",
    "skills",
    "src",
    "tests"
  ],
  "devTools": {
    "formatter": {
      "primary": "black",
      "options": ["--line-length=88"]
    },
    "importSorter": "isort",
    "linters": ["flake8", "mypy"],
    "typeChecking": true,
    "testRunner": "pytest",
    "testCommand": "pytest -q --maxfail=1",
    "coverage": {
      "enabled": true,
      "command": "pytest --cov=src --cov-report=xml"
    },
    "preCommit": [
      "black",
      "isort",
      "flake8",
      "mypy",
      "pytest"
    ]
  },
  "documentation": {
    "tool": "sphinx",
    "docsSource": "docs",
    "buildCommand": "sphinx-build -b html docs docs/_build/html",
    "serveCommand": "sphinx-autobuild docs docs/_build/html --open-browser",
    "requireDesignReference": true
  },
  "ci": {
    "provider": "github_actions",
    "workflows": {
      "lint_and_test": {
        "runs-on": "ubuntu-latest",
        "steps": [
          "checkout",
          "setup-python 3.11",
          "install dependencies (poetry install)",
          "run linters",
          "run tests"
        ]
      },
      "build_docs": {
        "runs-on": "ubuntu-latest",
        "steps": [
          "checkout",
          "setup-python 3.11",
          "install dependencies",
          "build docs"
        ]
      }
    },
    "requirePassingChecksBeforeMerge": true
  },
  "safety": {
    "riskProfile": "conservative",
    "networkPolicy": {
      "mode": "restricted",
      "allowedHosts": [
        "127.0.0.1",
        "localhost"
      ],
      "note": "Outbound network to live broker endpoints is disallowed by default"
    },
    "liveTrading": {
      "requireExplicitEnable": true,
      "envVar": "ALLOW_LIVE_TRADING",
      "default": false,
      "approvalArtifact": "designs/live_trading_approval.md",
      "approvalRequiredFrom": ["architect", "lead_developer"]
    },
    "simulationMode": {
      "envVar": "SIMULATION_MODE",
      "requiredForRun": true,
      "default": true
    },
    "secretsPolicy": {
      "storeSecretsOutsideRepo": true,
      "recommendedStorage": ["environment", "vault"],
      "disallowedInRepo": ["BROKER_API_KEY", "BROKER_SECRET", "PRIVATE_KEYS"]
    },
    "executionControls": {
      "disallowArbitraryRemoteCommands": true,
      "requireDesignReferenceBeforeRiskyChange": true
    }
  },
  "files": {
    "include": [
      "src/**",
      "docs/**",
      "tests/**",
      "designs/**",
      "skills/**",
      ".claude/**"
    ],
    "exclude": [
      "data/**",
      "secrets/**",
      "dist/**",
      ".venv/**"
    ],
    "importantFiles": {
      "designDocuments": "designs/README.md",
      "decisionLog": "docs/decision_logs/decisions.md",
      "skillsIndex": "skills/README.md"
    }
  },
  "commands": {
    "setup": "poetry install",
    "activateEnv": "source venv/bin/activate || poetry shell",
    "lint": "flake8 src tests && mypy src",
    "format": "black src tests docs && isort src tests",
    "test": "pytest -q",
    "coverage": "pytest --cov=src --cov-report=term-missing",
    "buildDocs": "sphinx-build -b html docs docs/_build/html"
  },
  "secrets": {
    "handledSecurely": true,
    "envRestricted": [
      "BROKER_API_KEY",
      "BROKER_SECRET",
      "VAULT_TOKEN"
    ],
    "neverCommitRule": true
  },
  "loggingAndTracing": {
    "decisionLogPath": "docs/decision_logs/decisions.md",
    "designDocPath": "designs/README.md",
    "changeLogPath": "docs/changelog.md",
    "recordDecisionOnRiskyChange": true
  },
  "editor": {
    "formatOnSave": true,
    "recommendedExtensions": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "eamodio.gitlens",
      "njpwerner.autodocstring"
    ]
  },
  "metadata": {
    "createdBy": "system-architect",
    "intendedUse": "development of automated trading system with emphasis on safety, docs, tests",
    "referencePriority": [
      "designs",
      "docs/decision_logs",
      "skills"
    ]
  }
}