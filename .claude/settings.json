{
  "projectName": "auto-trading-system",
  "language": "python",
  "pythonVersion": "3.11",
  "packageManager": "poetry",
  "entrypoint": "src/main.py",
  "folders": {
    "docs": "docs",
    "source": "src",
    "tests": "tests",
    "design": "design",
    "decisions": "decisions",
    "skills": "skills",
    "configs": "configs"
  },
  "priorityFiles": [
    "design/**",
    "decisions/**",
    "skills/**",
    "docs/**",
    "src/**",
    "tests/**",
    "README.md"
  ],
  "tooling": {
    "formatter": "black",
    "linters": [
      "flake8",
      "ruff"
    ],
    "typeChecker": "mypy",
    "testRunner": "pytest",
    "docTool": "mkdocs",
    "preCommit": "pre-commit",
    "securityScanner": "bandit"
  },
  "dependencies": [
    "pandas",
    "numpy",
    "pydantic",
    "requests",
    "aiohttp",
    "ccxt"
  ],
  "devDependencies": [
    "pytest",
    "pytest-cov",
    "black",
    "flake8",
    "ruff",
    "mypy",
    "pre-commit",
    "bandit",
    "mkdocs"
  ],
  "commands": {
    "test": "pytest --maxfail=1 -q",
    "lint": "ruff check src tests && flake8 src tests",
    "format": "black src tests docs",
    "typecheck": "mypy src",
    "docsBuild": "mkdocs build --clean"
  },
  "ci": {
    "enabled": true,
    "workflowName": "ci-python.yml",
    "runsOn": "ubuntu-latest",
    "steps": [
      "setup-python",
      "install-deps",
      "run-lint",
      "run-typecheck",
      "run-tests",
      "build-docs"
    ]
  },
  "repositoryLayout": {
    "docs": {
      "primary": "docs",
      "generator": "mkdocs"
    },
    "source": {
      "packageRoot": "src",
      "testsRoot": "tests"
    },
    "design": {
      "architecture": "design/architecture.md",
      "requirements": "design/requirements.md"
    },
    "decisions": {
      "decisionLog": "decisions/decision-log.md"
    },
    "skills": {
      "location": "skills",
      "pattern": "*.skill.md"
    }
  },
  "safety": {
    "networkAccess": {
      "allowedByDefault": false,
      "requireExplicitApprovalForExternalConnections": true
    },
    "secretsHandling": {
      "secretsFiles": [
        ".env",
        "configs/secrets.yaml",
        "configs/secrets.json"
      ],
      "ignoreInVcs": true
    },
    "tradingExecution": {
      "requireCredentialsAndApproval": true,
      "no-unsafe-actions-by-default": true
    },
    "reviewPriorities": [
      "design",
      "decisions",
      "skills"
    ]
  },
  "filesToIgnore": [
    ".env",
    "configs/secrets.yaml",
    "configs/secrets.json",
    ".venv",
    "__pycache__",
    "*.pyc"
  ]
}